from burp import IBurpExtender
from burp import IContextMenuFactory
from javax.swing import JMenuItem, JPanel, JLabel, JTextField, JOptionPane
import java.awt as awt
import re

class BurpExtender(IBurpExtender, IContextMenuFactory):
    
    def registerExtenderCallbacks(self, callbacks):
        self._callbacks = callbacks
        self._helpers = callbacks.getHelpers()
        
        callbacks.setExtensionName("Multi-Attack Repeater Multiplier")
        callbacks.registerContextMenuFactory(self)
        print "Multi-Attack Repeater Multiplier loaded successfully."

    def createMenuItems(self, invocation):
        self.context = invocation
        if invocation.getSelectedMessages():
            menu_list = []
            menu_item = JMenuItem("Send to Repeater N Times...", actionPerformed=self.handle_menu_click)
            menu_list.append(menu_item)
            return menu_list
        return None

    def handle_menu_click(self, event):
        selected_messages = self.context.getSelectedMessages()
        if not selected_messages:
            return
            
        message_info = selected_messages[0]
        http_service = message_info.getHttpService()
        request_bytes = message_info.getRequest()

        # Build your exact enhanced grid UI layout (6 rows, 2 columns)
        panel = JPanel(awt.GridLayout(6, 2, 5, 5))
        
        # Target Parameter Field (e.g., json key name)
        param_target_field = JTextField("id")
        
        # 4 Attack Payload Fields
        payload_field_1 = JTextField("<script>alert(0)</script>")
        payload_field_2 = JTextField("SQLi_Payload_Here")
        payload_field_3 = JTextField("CSRF_Payload_Here")
        payload_field_4 = JTextField("")  # Left blank by default
        
        # 1 Count Field
        count_field = JTextField("3")

        # Add components to the panel (Exact structure preserved)
        panel.add(JLabel("Target Parameter Name:"))
        panel.add(param_target_field)
        
        panel.add(JLabel("Attack 1 Payload:"))
        panel.add(payload_field_1)
        
        panel.add(JLabel("Attack 2 Payload:"))
        panel.add(payload_field_2)
        
        panel.add(JLabel("Attack 3 Payload:"))
        panel.add(payload_field_3)
        
        panel.add(JLabel("Attack 4 Payload:"))
        panel.add(payload_field_4)
        
        panel.add(JLabel("Number of Tabs per Attack:"))
        panel.add(count_field)

        # Show the pop-up modal
        result = JOptionPane.showConfirmDialog(
            None, 
            panel, 
            "Multi-Attack Parameter Configuration", 
            JOptionPane.OK_CANCEL_OPTION, 
            JOptionPane.PLAIN_MESSAGE
        )

        if result == JOptionPane.OK_OPTION:
            try:
                # Validate Tab Count
                count_str = count_field.getText().strip()
                if not count_str.isdigit():
                    raise ValueError("Please enter a valid number for the tab count.")
                count = int(count_str)
                
                target_param_name = param_target_field.getText().strip()
                if not target_param_name:
                    raise ValueError("Target Parameter Name cannot be empty.")

                # Gather all payloads from the UI
                payloads = [
                    payload_field_1.getText().strip(),
                    payload_field_2.getText().strip(),
                    payload_field_3.getText().strip(),
                    payload_field_4.getText().strip()
                ]

                is_https = 1 if http_service.getProtocol().lower() == "https" else 0
                processed_any = False

                # Split headers and body to modify the JSON safely
                request_info = self._helpers.analyzeRequest(request_bytes)
                headers = request_info.getHeaders()
                body_offset = request_info.getBodyOffset()
                
                # Convert request body bytes to a Python string
                request_string = self._helpers.bytesToString(request_bytes)
                body_string = request_string[body_offset:]

                # Loop through each provided payload
                for index, payload in enumerate(payloads, start=1):
                    if not payload:
                        continue
                    
                    # Regex pattern to locate the exact JSON key and value boundaries
                    pattern = r'("{}"\s*:\s*)("[^"]*"|\d+|true|false|null)'.format(re.escape(target_param_name))
                    match = re.search(pattern, body_string)
                    
                    if not match:
                        # Fallback: check if it's standard URL/body parameter if not found in JSON string
                        param_list = request_info.getParameters()
                        target_parameter = next((p for p in param_list if p.getName() == target_param_name), None)
                        
                        if not target_parameter:
                            JOptionPane.showMessageDialog(None, "Key/Parameter '" + target_param_name + "' not found in request body.", "Warning", JOptionPane.WARNING_MESSAGE)
                            return
                        
                        # Handle regular parameter
                        new_parameter = self._helpers.buildParameter(target_parameter.getName(), payload, target_parameter.getType())
                        modified_request = self._helpers.updateParameter(request_bytes, new_parameter)
                    else:
                        # Safely format payload for JSON strings vs literal numbers/booleans
                        replacement_value = '"{}"'.format(payload) if not (payload.isdigit() or payload in ["true", "false", "null"]) else payload
                        
                        # Fix: Use explicit string slicing instead of re.sub to avoid invalid group reference errors
                        prefix_match = match.group(1) # This is the `"id": ` part
                        start_idx = match.start()
                        end_idx = match.end()
                        
                        # Reconstruct the body strictly as text strings
                        modified_body_str = body_string[:start_idx] + prefix_match + replacement_value + body_string[end_idx:]
                        
                        # Rebuild the full request with original headers + our safely modified body text
                        modified_request = self._helpers.buildHttpMessage(headers, self._helpers.stringToBytes(modified_body_str))

                    processed_any = True
                    
                    # Generate N tabs for this payload iteration
                    for i in range(1, count + 1):
                        custom_tab_name = "Param_{}-Payload_{}-{}".format(target_param_name, index, i)
                        
                        self._callbacks.sendToRepeater(
                            http_service.getHost(),
                            http_service.getPort(),
                            is_https,
                            modified_request,
                            custom_tab_name
                        )
                
                if not processed_any:
                    JOptionPane.showMessageDialog(None, "All payload fields were empty. No tabs were generated.", "Warning", JOptionPane.WARNING_MESSAGE)

            except ValueError as e:
                JOptionPane.showMessageDialog(None, str(e), "Error", JOptionPane.ERROR_MESSAGE)
